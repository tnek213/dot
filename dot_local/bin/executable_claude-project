#!/usr/bin/env python3
"""Manage Claude Code's per-project leftovers (session transcripts, memory, file-history snapshots)."""

from __future__ import annotations

import argparse
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

CLAUDE = Path.home() / ".claude"
PROJECTS = CLAUDE / "projects"
FILE_HISTORY = CLAUDE / "file-history"
CWD_RE = re.compile(r'"cwd":"([^"]+)"')


def cpignore_path() -> Path:
    xdg = os.environ.get("XDG_CONFIG_HOME") or str(Path.home() / ".config")
    return Path(xdg) / "claude-project" / "cpignore"


def load_cpignore() -> list[Path]:
    path = cpignore_path()
    if not path.exists():
        return []
    entries: list[Path] = []
    for raw in path.read_text().splitlines():
        line = raw.split("#", 1)[0].strip()
        if not line:
            continue
        expanded = os.path.expandvars(os.path.expanduser(line))
        entries.append(Path(expanded).resolve(strict=False))
    return entries


def cpignore_match(target: Path, entries: list[Path]) -> Path | None:
    """Return the cpignore entry that protects target, or None."""
    t = target.resolve(strict=False)
    for entry in entries:
        if t == entry or entry in t.parents:
            return entry
    return None


def slug_for(path: Path) -> str:
    # Claude Code slugs absolute paths by replacing both '/' and '.' with '-'.
    return str(path.resolve()).replace("/", "-").replace(".", "-")


def session_ids(project_dir: Path) -> list[str]:
    return [j.stem for j in sorted(project_dir.glob("*.jsonl"))]


def du(path: Path) -> str:
    if not path.exists():
        return "—"
    try:
        out = subprocess.run(
            ["du", "-sh", str(path)], capture_output=True, text=True, check=True
        ).stdout
        return out.split()[0]
    except Exception:
        return "?"


def cwd_from_project(project_dir: Path) -> str | None:
    for jsonl in project_dir.glob("*.jsonl"):
        try:
            with jsonl.open() as f:
                for line in f:
                    m = CWD_RE.search(line)
                    if m:
                        return m.group(1)
        except OSError:
            continue
    return None


def have_gio() -> bool:
    return shutil.which("gio") is not None


class TrashError(Exception):
    pass


def trash(path: Path) -> None:
    r = subprocess.run(
        ["gio", "trash", "--", str(path)],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        raise TrashError(r.stderr.strip() or f"gio trash failed for {path}")


def confirm(prompt: str, *, assume_yes: bool) -> bool:
    if assume_yes:
        return True
    try:
        return input(f"{prompt} [y/N] ").strip().lower() in {"y", "yes"}
    except EOFError:
        return False


def iter_projects():
    """Yield (project_dir, cwd, cwd_is_guessed) for every dir under PROJECTS."""
    if not PROJECTS.exists():
        return
    for project_dir in sorted(PROJECTS.iterdir()):
        if not project_dir.is_dir():
            continue
        cwd = cwd_from_project(project_dir)
        if cwd is None:
            cwd = "/" + project_dir.name.lstrip("-").replace("-", "/")
            yield project_dir, cwd, True
        else:
            yield project_dir, cwd, False


def cmd_purge(args: argparse.Namespace) -> int:
    if not args.skip_trash and not have_gio():
        print(
            "gio (libglib2.0-bin) not found — cannot move to trash.\n"
            "Pass --skip-trash to delete permanently instead, or install gio.",
            file=sys.stderr,
        )
        return 2
    plans: list[tuple[Path, list[Path]]] = []
    rc = 0
    # Each arg may contain multiple paths separated by newlines, so that
    # `claude-project purge "$(claude-project query list orphans)"` works.
    projects: list[Path] = []
    for arg in args.projects:
        for line in str(arg).splitlines():
            line = line.strip()
            if line:
                projects.append(Path(line))

    if not args.force:
        ignore_entries = load_cpignore()
        blocked: list[tuple[Path, Path]] = []
        for project in projects:
            m = cpignore_match(project, ignore_entries)
            if m is not None:
                blocked.append((project, m))
        if blocked:
            print("Refusing to purge — protected by cpignore:", file=sys.stderr)
            for project, entry in blocked:
                print(f"  {project}  (matched {entry})", file=sys.stderr)
            print(f"Edit {cpignore_path()} or pass --force to override.", file=sys.stderr)
            return 1

    for project in projects:
        slug = slug_for(project)
        project_dir = PROJECTS / slug
        has_state = project_dir.exists()

        burn_targets: list[Path] = []
        if args.burn:
            for name in ("CLAUDE.md", ".claude"):
                p = project / name
                if p.exists() or p.is_symlink():
                    burn_targets.append(p)

        if not has_state and not burn_targets:
            print(f"No Claude project state at {project_dir}", file=sys.stderr)
            rc = 1
            continue

        ids = session_ids(project_dir) if has_state else []
        history_dirs = [FILE_HISTORY / sid for sid in ids if (FILE_HISTORY / sid).exists()]

        print(f"Project slug: {slug}")
        if has_state:
            print(f"  {project_dir}  ({du(project_dir)}, {len(ids)} sessions)")
        else:
            print(f"  {project_dir}  (no internal state)")
        if has_state:
            if history_dirs:
                print(f"  file-history ({len(history_dirs)} dirs):")
                for d in history_dirs:
                    print(f"    {d}  ({du(d)})")
            else:
                print("  file-history: none")
        if args.burn:
            if burn_targets:
                print("  burn:")
                for b in burn_targets:
                    print(f"    {b}  ({du(b)})")
            else:
                print("  burn: nothing (no CLAUDE.md or .claude at path)")
        plans.append((project_dir if has_state else None, history_dirs, burn_targets))

    if not plans:
        return rc or 1
    if args.dry_run:
        return rc

    verb = "Delete permanently" if args.skip_trash else "Move to trash"
    prompt = f"{verb} all of the above?" if len(plans) > 1 else f"{verb}?"
    if not confirm(prompt, assume_yes=args.yes):
        print("Aborted.")
        return 1

    def remove(p: Path) -> None:
        if args.skip_trash:
            if p.is_symlink() or p.is_file():
                p.unlink()
            else:
                shutil.rmtree(p)
        else:
            trash(p)

    try:
        for project_dir, history_dirs, burn_targets in plans:
            if project_dir is not None:
                remove(project_dir)
            for d in history_dirs:
                remove(d)
            for b in burn_targets:
                remove(b)
    except TrashError as e:
        print(f"gio trash refused: {e}", file=sys.stderr)
        print("Re-run with --skip-trash to delete permanently.", file=sys.stderr)
        return 1
    print("Done.")
    return rc


def cmd_internal_list(args: argparse.Namespace) -> int:
    want_orphans = args.kind == "orphans"
    found = False
    for project_dir, cwd, guessed in iter_projects():
        exists = Path(cwd).exists()
        is_orphan = not exists
        if want_orphans != is_orphan:
            continue
        # Skip guessed entries: their path was reverse-engineered from the
        # slug (no transcripts to read cwd from) and may be wrong.
        if guessed:
            continue
        found = True
        print(cwd)
    if not found:
        print(f"No {args.kind} projects.", file=sys.stderr)
    return 0


PRUNE_DIRS = {".git", "node_modules", "__pycache__", ".venv", "venv", ".mypy_cache", ".tox", ".claude", "Trash"}


def is_pruned(name: str) -> bool:
    return name in PRUNE_DIRS or name.startswith(".Trash-")


def cmd_fs_burnable(args: argparse.Namespace) -> int:
    ignore_entries = load_cpignore()

    current: set[Path] = set()
    for _project_dir, cwd, guessed in iter_projects():
        if guessed:
            continue
        p = Path(cwd)
        if p.exists():
            current.add(p.resolve())

    matches: list[Path] = []
    for root_arg in args.paths:
        root = Path(root_arg)
        if not root.is_dir():
            print(f"{root} is not a directory", file=sys.stderr)
            continue
        for dirpath, dirnames, filenames in os.walk(root):
            dirnames[:] = [
                d for d in dirnames
                if not is_pruned(d)
                and cpignore_match(Path(dirpath) / d, ignore_entries) is None
            ]
            d = Path(dirpath)
            if cpignore_match(d, ignore_entries) is not None:
                dirnames[:] = []
                continue
            has_md = "CLAUDE.md" in filenames
            has_dot = (d / ".claude").is_dir()
            if not (has_md or has_dot):
                continue
            try:
                resolved = d.resolve()
            except OSError:
                continue
            if resolved in current:
                continue
            matches.append(d)
    matches.sort(key=lambda p: len(p.parts), reverse=True)
    for d in matches:
        print(d)
    if not matches:
        print("No burnable directories.", file=sys.stderr)
    return 0


def cmd_move(args: argparse.Namespace) -> int:
    srcs = [Path(s) for s in args.srcs]
    dst = Path(args.dst)

    if len(srcs) > 1 and not dst.is_dir():
        print(f"DST {dst} must be an existing directory when moving multiple sources.", file=sys.stderr)
        return 2

    # plan entry: (src_abs, final_abs, old_project, new_project, is_late_unorphan, has_project)
    plan: list[tuple[Path, Path, Path, Path, bool, bool]] = []
    for src in srcs:
        src_exists = src.exists()
        late_unorphan = False
        if not src_exists:
            if not args.late:
                print(f"{src} does not exist", file=sys.stderr)
                return 1
            late_unorphan = True

        # Determine final path.
        if late_unorphan:
            # Filesystem move already happened. For multi-src, the new path
            # is DST/basename(SRC); for single SRC, the new path is DST itself.
            final = (dst / src.name) if len(srcs) > 1 else dst
        else:
            if len(srcs) > 1:
                final = dst / src.name
            else:
                final = dst / src.name if dst.is_dir() else dst

        src_abs = src.resolve()
        final_abs = final.resolve() if final.exists() else (final.parent.resolve() / final.name)

        old_project = PROJECTS / slug_for(src_abs)
        new_project = PROJECTS / slug_for(final_abs)
        has_project = old_project.exists()

        if not has_project and late_unorphan:
            # --late requires existing project state to migrate; without it there's nothing to do.
            print(
                f"{src} is not a current Claude project (no {old_project})"
                " (run `claude-project query list orphans` to see known orphan projects)",
                file=sys.stderr,
            )
            return 1

        if late_unorphan:
            if not final_abs.exists():
                print(f"With --late, destination {final_abs} must already exist on disk", file=sys.stderr)
                return 1
        else:
            if final_abs.exists():
                print(f"Destination {final_abs} already exists", file=sys.stderr)
                return 1

        if has_project and new_project.exists() and new_project != old_project:
            print(f"Claude project state for {final_abs} already exists ({new_project})", file=sys.stderr)
            return 1

        plan.append((src_abs, final_abs, old_project, new_project, late_unorphan, has_project))

    for src_abs, final_abs, old_project, new_project, late_unorphan, has_project in plan:
        if not late_unorphan:
            shutil.move(str(src_abs), str(final_abs))
        if has_project and old_project != new_project:
            old_project.rename(new_project)
            old_marker = f'"cwd":"{src_abs}"'
            new_marker = f'"cwd":"{final_abs}"'
            for jsonl in new_project.glob("*.jsonl"):
                text = jsonl.read_text()
                if old_marker in text:
                    jsonl.write_text(text.replace(old_marker, new_marker))
        elif not has_project:
            print(f"  (no Claude project state to migrate for {src_abs})", file=sys.stderr)
        print(f"Moved {src_abs} -> {final_abs}")
    return 0


CONSUME_INSTRUCTIONS = """\
# Read me

You are picking up a folder that holds Claude Code per-project state which
the user decided to retire. The data was moved here (rather than deleted
outright) so an AI agent can mine anything useful before it is gone.

The directory name (`consume_then_delete_<slug>`) encodes the slugified form
of the original project's absolute filesystem path. The slug is **lossy** —
`-` could have come from `/`, `.`, or a literal `-`. Treat the `"cwd":"…"`
field inside the transcripts as authoritative for the original path.

## What's in this directory

- `projects/`       — session transcripts (`.jsonl` files) and the project's
                      auto-memory directory.
- `file-history/`   — per-session file snapshots (Claude's local undo store);
                      only present if there was any.

Each `.jsonl` line is one event with at least `type` and (often) `cwd`. You
can `jq -c '. | select(.type=="…")'` or grep for specific fields. The
`memory/` subdirectory has `MEMORY.md` (an index) and one file per memory.

## Your task

1. **Orient first** so you don't re-extract things that are already captured:
   read `~/.claude/CLAUDE.md`, the current user `MEMORY.md`, and skim
   `~/.claude/skills/` for relevant skill files.

2. **Skim the transcripts and memory files.** Keep things that are:
   - non-obvious from current code/state,
   - lessons the user repeated or corrected you on more than once,
   - references (URLs, paths, IDs) the user still relies on,
   - follow-up tasks or ideas to revisit.

   Skip one-off debug notes, transient task state, and anything trivially
   derivable from the codebase or `git log`.

3. **Write each kept item to the right long-term home.** Use concrete paths:
   - persistent skill rules → `~/.claude/skills/<skill>/SKILL.md`,
   - mail tone → `~/.local/share/mail-extra/tone/<lang>.md` or
                 `~/.local/share/mail-extra/tone/<account>/<lang>.md`,
   - your auto-memory for the *current* project →
     `~/.claude/projects/<current-slug>/memory/` (plus a line in `MEMORY.md`),
   - global user instructions → `~/.claude/CLAUDE.md`.

   Don't invent new locations; if nothing fits, ask the user.

4. **Report to the user** in a short summary: each item you kept and where
   you put it (or "nothing worth keeping").

5. **Delete this entire directory.** This is mandatory and immediate.
   The word *consume* means absorbed and gone — `consume_then_delete_
   <slug>/` exists only for this one review pass. As soon as step 4 is
   sent, run `rm -rf` on this directory. Do not defer, do not keep it
   "just in case," do not leave it for a "next session." If something
   genuinely prevents deletion, say so explicitly in the report — silent
   non-deletion is a bug.

6. **Also delete the original source directory** (the path encoded in
   the slug, if it still exists on disk). Same rule, same finality: the
   source is being absorbed into the destination project and must go
   away. Working files that lived there (notes, configs, scripts, data,
   CLAUDE.md) get triaged exactly like the transcripts in step 2:
   genuinely-useful content goes to its long-term home (step 3's list,
   or the destination project's own files); everything else is
   discarded. Decide and act — do **not** ask the user "should I keep
   this file?" as a way to defer the cleanup. If a file is borderline,
   default to moving it into the destination project (where it can be
   pruned later) rather than leaving the source dir behind. Once
   triage is done, `rm -rf` the source.
"""


def cmd_consume(args: argparse.Namespace) -> int:
    srcs = [Path(s) for s in args.srcs]
    dst = Path(args.dst)

    if not dst.is_dir():
        print(f"DST {dst} must be an existing directory.", file=sys.stderr)
        return 2

    if not args.force:
        ignore_entries = load_cpignore()
        blocked = [(s, m) for s in srcs if (m := cpignore_match(s, ignore_entries)) is not None]
        if blocked:
            print("Refusing to consume — protected by cpignore:", file=sys.stderr)
            for src, entry in blocked:
                print(f"  {src}  (matched {entry})", file=sys.stderr)
            print(f"Edit {cpignore_path()} or pass --force to override.", file=sys.stderr)
            return 1

    plan: list[tuple[Path, str, Path, Path, list[Path]]] = []
    seen_slugs: set[str] = set()
    for src in srcs:
        src_abs = src.resolve()
        slug = slug_for(src_abs)
        if slug in seen_slugs:
            print(f"{src} resolves to slug {slug} which is already in this batch — skipping duplicate", file=sys.stderr)
            continue
        project_dir = PROJECTS / slug
        if not project_dir.exists():
            print(f"{src} is not a Claude project (no {project_dir})", file=sys.stderr)
            return 1
        ids = session_ids(project_dir)
        history_dirs = [FILE_HISTORY / sid for sid in ids if (FILE_HISTORY / sid).exists()]

        # Pick the first available consume_then_delete_<slug>[_N] under DST.
        base = f"consume_then_delete_{slug}"
        target = dst / base
        n = 2
        while target.exists():
            target = dst / f"{base}_{n}"
            n += 1

        plan.append((src_abs, slug, target, project_dir, history_dirs))
        seen_slugs.add(slug)

    if not plan:
        print("Nothing to consume.", file=sys.stderr)
        return 1

    for src_abs, slug, target, project_dir, history_dirs in plan:
        print(f"{src_abs}  [{slug}]  -> {target}")
        print(f"  {project_dir}  ({du(project_dir)})")
        for d in history_dirs:
            print(f"  {d}  ({du(d)})")

    if not confirm("Proceed?", assume_yes=args.yes):
        print("Aborted.")
        return 1

    for src_abs, slug, target, project_dir, history_dirs in plan:
        target.mkdir()
        (target / "INSTRUCTIONS.md").write_text(CONSUME_INSTRUCTIONS)
        shutil.move(str(project_dir), str(target / "projects"))
        if history_dirs:
            (target / "file-history").mkdir()
            for d in history_dirs:
                shutil.move(str(d), str(target / "file-history" / d.name))
        print(f"Moved into {target}")
    return 0


TS_RE = re.compile(r'"timestamp":"([^"]+)"')


def session_timestamps(jsonl: Path) -> tuple[str | None, str | None]:
    """Return (first, last) ISO timestamps found in the .jsonl, or (None, None)."""
    first: str | None = None
    last: str | None = None
    try:
        with jsonl.open() as f:
            for line in f:
                m = TS_RE.search(line)
                if not m:
                    continue
                ts = m.group(1)
                if first is None or ts < first:
                    first = ts
                if last is None or ts > last:
                    last = ts
    except OSError:
        pass
    return first, last


def cmd_show(args: argparse.Namespace) -> int:
    rc = 0
    for i, src in enumerate(args.projects):
        if i:
            print()
        path = Path(src).resolve()
        slug = slug_for(path)
        project_dir = PROJECTS / slug
        if not project_dir.exists():
            print(f"{path}  [no project state at {project_dir}]", file=sys.stderr)
            rc = 1
            continue

        cwd = cwd_from_project(project_dir) or "(no cwd in transcripts)"
        fs_state = "exists" if Path(cwd).exists() else "ORPHAN"
        print(f"{cwd}  [{slug}]  ({fs_state})")
        print(f"  Project: {project_dir}  ({du(project_dir)})")

        jsonls = sorted(project_dir.glob("*.jsonl"))
        if jsonls:
            print(f"  Sessions ({len(jsonls)}):")
            for j in jsonls:
                first, last = session_timestamps(j)
                span = f"{first} .. {last}" if first else "(no timestamps)"
                fh = FILE_HISTORY / j.stem
                fh_part = f"fh:{du(fh)}" if fh.exists() else "fh:-"
                print(f"    {j.stem}  {span}  {du(j)}  {fh_part}")
        else:
            print("  Sessions: none")

        memory_dir = project_dir / "memory"
        if memory_dir.exists():
            files = sorted(p.name for p in memory_dir.iterdir() if p.is_file())
            if files:
                print(f"  Memory ({len(files)}):")
                for name in files:
                    print(f"    {name}")
            else:
                print("  Memory: (empty)")
        else:
            print("  Memory: none")
    return rc


TOP_DESCRIPTION = "Inspect and manage Claude Code's per-project state."

TOP_EPILOG = """\
State locations:
  ~/.claude/projects/<slug>/   session transcripts and auto-memory
  ~/.claude/file-history/      per-session file snapshots

Ignore file:
  $XDG_CONFIG_HOME/claude-project/cpignore (default ~/.config/...)
  One path per line; # comments; ~ and $VARS expanded. A path is
  protected if it equals or descends from any listed entry. Affects
  `purge`, `consume`, and `list burnable`. Override with --force.
"""


def _positional_repr(action: argparse.Action) -> str:
    mv = action.metavar or action.dest.upper()
    if action.nargs == "+":
        return f"{mv}..."
    if action.nargs == "*":
        return f"[{mv}...]"
    if action.nargs == "?":
        return f"[{mv}]"
    return mv


def build_synopsis(parser: argparse.ArgumentParser, prog: str, prefix: str = "") -> list[str]:
    subs = [a for a in parser._actions if isinstance(a, argparse._SubParsersAction)]
    if subs:
        lines: list[str] = []
        for name, sp in subs[0].choices.items():
            new_prefix = f"{prefix} {name}" if prefix else name
            lines.extend(build_synopsis(sp, prog, new_prefix))
        return lines
    has_opts = any(
        a.option_strings and not isinstance(a, argparse._HelpAction)
        for a in parser._actions
    )
    forms: list[str] = getattr(parser, "synopsis_forms", None) or [
        " ".join(
            _positional_repr(a)
            for a in parser._actions
            if not a.option_strings and not isinstance(a, argparse._HelpAction)
        )
    ]
    lines = []
    for form in forms:
        parts = [prog, prefix]
        if has_opts:
            parts.append("[OPTION]...")
        if form:
            parts.append(form)
        lines.append("  " + " ".join(parts))
    return lines


BASH_COMPLETION = r"""# bash completion for claude-project
# Source it: source <(claude-project completion bash)
_claude_project()
{
    local cur prev cword
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    cword=$COMP_CWORD

    local top_cmds="purge list move consume show completion"
    local cmd="" sub=""
    (( cword >= 1 )) && cmd="${COMP_WORDS[1]}"
    (( cword >= 2 )) && sub="${COMP_WORDS[2]}"

    if (( cword == 1 )); then
        COMPREPLY=( $(compgen -W "$top_cmds -h --help" -- "$cur") )
        return
    fi

    case "$cmd" in
        purge)
            if [[ "$cur" == -* ]]; then
                COMPREPLY=( $(compgen -W "-n --dry-run -y --yes --burn --skip-trash --force" -- "$cur") )
            else
                local tracked
                tracked="$(claude-project list current 2>/dev/null; claude-project list orphans 2>/dev/null)"
                COMPREPLY=( $(compgen -W "$tracked" -- "$cur") )
                COMPREPLY+=( $(compgen -d -- "$cur") )
            fi
            ;;
        list)
            if (( cword == 2 )); then
                COMPREPLY=( $(compgen -W "orphans current burnable" -- "$cur") )
            elif [[ "$sub" == burnable ]]; then
                COMPREPLY=( $(compgen -d -- "$cur") )
            fi
            ;;
        move)
            if [[ "$cur" == -* ]]; then
                COMPREPLY=( $(compgen -W "--late" -- "$cur") )
            else
                COMPREPLY=( $(compgen -d -- "$cur") )
            fi
            ;;
        consume)
            if [[ "$cur" == -* ]]; then
                COMPREPLY=( $(compgen -W "-y --yes --force" -- "$cur") )
            else
                COMPREPLY=( $(compgen -d -- "$cur") )
            fi
            ;;
        show)
            local tracked
            tracked="$(claude-project list current 2>/dev/null; claude-project list orphans 2>/dev/null)"
            COMPREPLY=( $(compgen -W "$tracked" -- "$cur") )
            COMPREPLY+=( $(compgen -d -- "$cur") )
            ;;
        completion)
            if (( cword == 2 )); then
                COMPREPLY=( $(compgen -W "bash" -- "$cur") )
            fi
            ;;
    esac
}
complete -o filenames -F _claude_project claude-project
"""


def cmd_completion(args: argparse.Namespace) -> int:
    if args.shell == "bash":
        sys.stdout.write(BASH_COMPLETION)
        return 0
    print(f"Unknown shell: {args.shell}", file=sys.stderr)
    return 2


def main() -> int:
    p = argparse.ArgumentParser(
        description=TOP_DESCRIPTION,
        epilog=TOP_EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = p.add_subparsers(dest="cmd", required=True, metavar="COMMAND")

    pp = sub.add_parser("purge", help="Delete project state + file-history for a given project.")
    pp.add_argument("projects", type=Path, nargs="+", metavar="PATH", help="Project directories (need not still exist).")
    pp.add_argument("-n", "--dry-run", action="store_true", help="List what would be deleted; don't delete.")
    pp.add_argument("-y", "--yes", action="store_true", help="Don't prompt — delete after the listing.")
    pp.add_argument("--burn", action="store_true", help="Also delete CLAUDE.md and .claude/ from each project path on disk.")
    pp.add_argument("--skip-trash", action="store_true", help="Delete permanently instead of moving to trash via `gio trash`.")
    pp.add_argument("--force", action="store_true", help="Override cpignore protection.")
    pp.set_defaults(func=cmd_purge)

    pl = sub.add_parser("list", help="List orphan, current, or burnable projects.", description="List projects.")
    lsub = pl.add_subparsers(dest="lcmd", required=True, metavar="KIND")

    plo = lsub.add_parser("orphans", help="Tracked projects whose recorded cwd no longer exists.")
    plo.set_defaults(func=cmd_internal_list, kind="orphans")

    plc = lsub.add_parser("current", help="Tracked projects whose recorded cwd still exists.")
    plc.set_defaults(func=cmd_internal_list, kind="current")

    plb = lsub.add_parser(
        "burnable",
        help="Filesystem scan: dirs with CLAUDE.md or .claude/ that aren't tracked current projects.",
        description=(
            "Recursively scan each PATH for directories containing CLAUDE.md\n"
            "or .claude/, excluding those that are tracked current Claude\n"
            "projects. Output is deepest-first. Prunes: "
            + ", ".join(sorted(PRUNE_DIRS)) + ", .Trash-*."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    plb.add_argument("paths", nargs="+", metavar="PATH", help="Directories to scan recursively.")
    plb.set_defaults(func=cmd_fs_burnable)

    pm = sub.add_parser("move", help="Move or rename a current project, updating Claude state.")
    pm.add_argument("srcs", nargs="+", metavar="SOURCE", help="Source project director(y/ies). Each must currently be a Claude project.")
    pm.add_argument("dst", metavar="DEST", help="Destination. With multiple SOURCEs, must be an existing directory.")
    pm.add_argument("--late", action="store_true", help="Allow SOURCE to be a missing path if it's an orphan project — the filesystem move already happened, so just update Claude state. With --late, DEST (or DEST/<basename> for multi-source) must already exist on disk.")
    pm.synopsis_forms = ["SOURCE DEST", "SOURCE... DIRECTORY"]

    pc = sub.add_parser("consume", help="Stage a project's Claude internals under DEST for an AI agent to review and then delete.")
    pc.add_argument("srcs", nargs="+", metavar="SOURCE", help="Project paths whose Claude internals should be relocated.")
    pc.add_argument("dst", metavar="DEST", help="Existing directory under which consume_then_delete_<slug>/ is created.")
    pc.add_argument("-y", "--yes", action="store_true", help="Don't prompt — proceed after the listing.")
    pc.add_argument("--force", action="store_true", help="Override cpignore protection.")
    pc.set_defaults(func=cmd_consume)
    pc.synopsis_forms = ["SOURCE... DIRECTORY"]

    ps = sub.add_parser("show", help="Summarize stored Claude state for one or more projects.")
    ps.add_argument("projects", type=Path, nargs="+", metavar="PATH", help="Project paths (need not still exist).")
    ps.set_defaults(func=cmd_show)
    pm.set_defaults(func=cmd_move)

    pcomp = sub.add_parser("completion", help="Print shell completion script to stdout.")
    pcomp.add_argument("shell", choices=("bash",), help="Shell to generate completion for.")
    pcomp.set_defaults(func=cmd_completion)
    pcomp.synopsis_forms = ["bash"]

    synopsis = "\n".join(build_synopsis(p, p.prog))
    p.description = TOP_DESCRIPTION + "\n\nSynopsis:\n" + synopsis

    args = p.parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
